# -----------------------------------------------------------------------------
# Secret and environment-specific values
# Keep structure/configuration defaults in config/platform.toml
# Override with environment variables only when needed.
# -----------------------------------------------------------------------------

APP_NAME=Agent Platform V1
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: point to a structured TOML config file
# Default is backend/config/platform.toml
APP_CONFIG_FILE=

# -----------------------------------------------------------------------------
# LLM
# -----------------------------------------------------------------------------
LLM_PROVIDER=openai_compat
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=60
LLM_TEMPERATURE=0.2

# -----------------------------------------------------------------------------
# Search / Web search
# -----------------------------------------------------------------------------
SEARCH_PROVIDER=duckduckgo
SEARCH_MAX_RESULTS=5
TAVILY_API_KEY=
SERPAPI_API_KEY=
PERPLEXITY_API_KEY=
SEARXNG_URL=

# -----------------------------------------------------------------------------
# Embedding / RAG
# -----------------------------------------------------------------------------
EMBED_PROVIDER=none
EMBED_MODEL=
EMBED_BASE_URL=
EMBED_API_KEY=
RAG_BACKEND=local
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_QUERY_REWRITE_MODE=hybrid
RAG_MQE_VARIANTS=4
RAG_HYDE_MAX_TOKENS=220
RAG_RERANK_STRATEGY=feature
RAG_RERANK_TOP_N=12
RAG_URL_TIMEOUT_SECONDS=20
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=agent_platform_v1
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
STORAGE_ROOT=
HISTORY_DB_PATH=
MEMORY_DB_PATH=
TRACE_DB_PATH=
RAG_STORE_PATH=
NOTES_PATH=
MEMORY_BACKEND=sqlite
MEMORY_EXTRACTION_MODE=hybrid
MEMORY_EMBEDDING_MODE=auto
MEMORY_GRAPH_ENABLED=true
MEMORY_PERCEPTUAL_ENABLED=true
MEMORY_FORGETTING_ENABLED=true
MEMORY_CONFLICT_STRATEGY=confidence
MEMORY_LOCAL_EMBEDDING_DIMENSIONS=128

# -----------------------------------------------------------------------------
# MCP / Integrations
# -----------------------------------------------------------------------------
MCP_ENABLED=false
MCP_DEFAULT_TRANSPORT=stdio
GITHUB_PERSONAL_ACCESS_TOKEN=
AMAP_API_KEY=
UNSPLASH_ACCESS_KEY=
UNSPLASH_SECRET_KEY=

# -----------------------------------------------------------------------------
# Runtime tuning
# -----------------------------------------------------------------------------
DEFAULT_HISTORY_LIMIT=20
DEFAULT_CONTEXT_TOKEN_BUDGET=6000
DEFAULT_TOOL_ITERATIONS=2
RESEARCH_DEFAULT_TASK_COUNT=4
RESEARCH_SOURCES_PER_TASK=5
RESEARCH_MAX_PARALLEL_TASKS=3
